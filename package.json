{
  "name": "bureau",
  "productName": "Bureau",
  "version": "1.0.13",
  "description": "Local-first desktop mission control for development projects",
  "main": "./.vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "release": "npm run release:patch && git push origin main --follow-tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "icons:build": "node scripts/build-icons.mjs",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:security": "node scripts/check-forbidden-apis.mjs",
    "format:check": "prettier --check src tests",
    "format": "prettier --write src tests",
    "dev": "node scripts/dev.mjs",
    "postinstall": "node scripts/patch-native-build.mjs"
  },
  "keywords": [
    "electron",
    "developer-tools",
    "project-manager",
    "dashboard"
  ],
  "author": "Bureau",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-vite": "^7.8.0",
    "@felixrieseberg/electron-forge-maker-nsis": "^7.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.15.3",
    "@types/pidusage": "^2.0.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.2.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "sharp": "^0.35.3",
    "to-ico": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.1.2"
